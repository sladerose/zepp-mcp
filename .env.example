# Zepp Life / Mi Fit cloud session credentials
# Extract apptoken from browser DevTools at https://user.huami.com/privacy2/index.html
ZEPP_APP_TOKEN=your_app_token_here

# Your Zepp Life user ID (visible in app profile or DevTools response)
ZEPP_USER_ID=your_user_id_here

# Region: eu | us | cn
ZEPP_REGION=eu

# Optional: timezone for date grouping (default: UTC)
# ZEPP_TIMEZONE=Africa/Johannesburg

# Optional: how many days of history to sync on first run (default: 30)
# SYNC_LOOKBACK_DAYS=90
